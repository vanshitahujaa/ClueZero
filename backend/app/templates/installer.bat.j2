@echo off
setlocal DisableDelayedExpansion

set SERVER_URL={{ server_public_url }}
set TOKEN={{ token }}
set HOTKEY={{ hotkey }}
set INSTALL_DIR=%USERPROFILE%\.cluezero

echo [ClueZero] Installing for {{ name }}...

if not exist "%INSTALL_DIR%" mkdir "%INSTALL_DIR%"

echo [ClueZero] Stopping any running agent on this machine...
wmic process where "name='powershell.exe' and commandline like '%%agent.ps1%%'" call terminate >nul 2>&1

echo [ClueZero] Downloading PowerShell agent...
%SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "(New-Object System.Net.WebClient).DownloadFile('%SERVER_URL%/binary/windows', '%INSTALL_DIR%\agent.ps1')"
if %errorlevel% neq 0 (
    echo [ClueZero][ERROR] Failed to download agent.ps1 from %SERVER_URL%/binary/windows
    exit /b 1
)

echo [ClueZero] Writing config...
> "%INSTALL_DIR%\config.ini" (
    echo [cluezero]
    echo server_url=%SERVER_URL%
    echo token=%TOKEN%
    echo hotkey=%HOTKEY%
)

echo [ClueZero] Launching agent silently in background...
start "" /B %SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe -WindowStyle Hidden -NoProfile -ExecutionPolicy Bypass -File "%INSTALL_DIR%\agent.ps1"

echo [ClueZero] Done. Press %HOTKEY% to capture + process a screenshot.
