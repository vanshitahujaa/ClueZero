#!/usr/bin/env bash
set -euo pipefail

SERVER_URL="{{ server_public_url }}"
TOKEN="{{ token }}"
HOTKEY="{{ hotkey }}"
INSTALL_DIR="$HOME/.cluezero"

echo "[ClueZero] Installing for {{ name }}..."
mkdir -p "$INSTALL_DIR"

echo "[ClueZero] Stopping any running agent on this machine..."
pkill -f "$INSTALL_DIR/agent" 2>/dev/null || true

case "$(uname -s)" in
    Darwin)  BINARY_PATH="binary/darwin" ;;
    Linux)   BINARY_PATH="binary/linux" ;;
    *)
        echo "[ClueZero][ERROR] Unsupported OS: $(uname -s)"
        exit 1
        ;;
esac

echo "[ClueZero] Downloading agent binary for $(uname -s)..."
curl -# -fSL -o "$INSTALL_DIR/agent" "$SERVER_URL/$BINARY_PATH"
chmod +x "$INSTALL_DIR/agent"
# macOS Gatekeeper: clear the quarantine flag so the unsigned binary can run.
if [ "$(uname -s)" = "Darwin" ]; then
    xattr -d com.apple.quarantine "$INSTALL_DIR/agent" 2>/dev/null || true
fi

echo "[ClueZero] Writing config..."
cat > "$INSTALL_DIR/config.ini" <<EOF
[cluezero]
server_url=$SERVER_URL
token=$TOKEN
hotkey=$HOTKEY
EOF

echo "[ClueZero] Launching agent silently in background..."
nohup "$INSTALL_DIR/agent" >/dev/null 2>&1 &
disown || true

echo "[ClueZero] Done. Press $HOTKEY to capture + process a screenshot."
