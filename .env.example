# =========================
# ClueZero Configuration
# =========================

# ── Database (Neon Postgres) ─────────────────────────────────────────────
# Paste the full connection string from Neon. sslmode=require / channel_binding
# params are tolerated — the app strips them before handing to asyncpg.
DATABASE_URL=postgresql://user:pass@host/dbname

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM ──────────────────────────────────────────────────────────────────
# Provider: "openai" or "gemini". Switch freely without code changes.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_BASE_URL=
# Comma-separated list. First key is used for now; the comma-list is kept for
# future rotation. Put your OpenAI key here.
LLM_API_KEYS=sk-...

# Pricing (per 1K tokens, USD). Edit to match the LLM_MODEL you set above.
# gpt-4o is typical: input $0.005 / output $0.015 per 1K.
LLM_INPUT_PRICE_PER_1K=0.005
LLM_OUTPUT_PRICE_PER_1K=0.015

# ── Admin panel (HTTP Basic) ─────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── Sessions / LIFO ──────────────────────────────────────────────────────
# Seconds without a /session/ping before a session is considered dead.
SESSION_HEARTBEAT_TIMEOUT=90

# ── Server / public URL ──────────────────────────────────────────────────
# Embedded in per-user installers. Use the URL that clients will reach.
SERVER_PUBLIC_URL=http://localhost:8000

# ── Image processing ─────────────────────────────────────────────────────
MAX_IMAGE_SIZE_KB=512
IMAGE_QUALITY=65
IMAGE_MAX_RESOLUTION=720

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_SECONDS=15

# ── Job TTLs (Redis-side) ────────────────────────────────────────────────
JOB_TTL_SECONDS=600
JOB_RESULT_TTL_SECONDS=300

# ── Server bind ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Default prompt ───────────────────────────────────────────────────────
DEFAULT_PROMPT=If there is a coding problem visible in the screenshot, provide ONLY the raw code solution in the language shown. Do NOT include any explanations, do NOT include markdown formatting (like ```), and do NOT include comments in the code. Output purely the code required. If it's not a coding problem, answer as concisely as possible.
